{
  "expo": {
    "name": "Paprr",
    "slug": "paprr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "paprr",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.paprr",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Paprr to access your camera to update your profile photo.",
        "NSPhotoLibraryUsageDescription": "Allow Paprr to access your photo library to update your profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5F5F5"
      },
      "package": "app.rork.paprr",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Paprr to access your photo library to update your profile photo.",
          "cameraPermission": "Allow Paprr to access your camera to update your profile photo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
